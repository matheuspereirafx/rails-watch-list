<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><%= @list.name %></h1>
    <%= link_to "Add Movie", new_list_bookmark_path(@list), class: "btn btn-primary" %>
  </div>

  <% if @list.movies.any? %>
    <div class="row">
      <% @list.movies.each do |movie| %>
        <div class="col-md-3 mb-4">
          <div class="card h-100">
            <%= image_tag movie.poster_url, class: "card-img-top", alt: movie.title %>
            <div class="card-body">
              <h5 class="card-title"><%= movie.title %></h5>
              <p class="card-text">
                <small class="text-muted">⭐ <%= movie.rating %>/10</small>
              </p>
              <% bookmark = @list.bookmarks.find_by(movie: movie) %>
              <%= link_to "Remove", bookmark_path(bookmark),
                  data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                  class: "btn btn-sm btn-outline-danger" %>
            </div>
            <div class="card-footer">
              <small class="text-muted">
                💬 <%= @list.bookmarks.find_by(movie: movie).comment %>
              </small>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info">
      <p>No movies in this list yet.</p>
      <%= link_to "Add your first movie", new_list_bookmark_path(@list), class: "btn btn-primary" %>
    </div>
  <% end %>

  <%= link_to "Back to Lists", lists_path, class: "btn btn-secondary mt-3" %>
</div>
